# 複製此檔案為 .env，填入實際值後啟動專案
# 注意：.env 禁止 commit，此檔案（.env.example）需要 commit

# =====================
# 應用程式
# =====================
NODE_ENV=development
PORT=3000

# =====================
# 資料庫
# =====================
DATABASE_URL=

# =====================
# JWT
# =====================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =====================
# CORS
# =====================
CORS_ORIGIN=http://localhost:5173

# =====================
# 前端（Vite）
# =====================
VITE_API_BASE_URL=http://localhost:3000/api/v1
